flowchart TD
    BF["🗂 Backup Files\n(txt config files on disk, per device)"]
    PA["⚙️ lib/parser.js\n(FortiGate / PA / Juniper / F5)"]
    MC["🧠 In-memory Cache\n(secRules · natRules · addresses\nvipMap · vipgrpMap · schedules)"]
    API["🌐 Express API — server.js\n(/api/data · /api/reload · /api/status)"]
    FE["💻 public/index.html\n(browser frontend · getFilteredData)"]
